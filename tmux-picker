#!/bin/zsh
# tmux session picker вҖ” launched directly by Terminal.app as the startup command

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

[ -t 0 ] || exec zsh
printf '\033]0;workspaces\007'
clear

tmpfiles=()
_cleanup() { rm -f "${tmpfiles[@]}"; }
trap _cleanup EXIT

_mktemp() { local f=$(mktemp); tmpfiles+=("$f"); echo "$f"; }

tmpfile=$(_mktemp)

printf "1 вҖ” single panel\n2 вҖ” side by side\n3 вҖ” one left, two right\n4 вҖ” 2x2 grid" \
  | fzf --prompt="Layout> " --height=60% --reverse \
    --preview 'case {1} in
      1) printf "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ               в”Ӯ\nв”Ӯ               в”Ӯ\nв”Ӯ               в”Ӯ\nв”Ӯ               в”Ӯ\nв”Ӯ               в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\n  Single panel" ;;
      2) printf "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\n  Side by side" ;;
      3) printf "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\n  One left, two right" ;;
      4) printf "в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\nв”Ӯ       в”Ӯ       в”Ӯ\nв”Ӯ       в”Ӯ       в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n\n  2x2 grid" ;;
    esac' \
    --preview-window right:35% \
  > "$tmpfile"
layout=$(<"$tmpfile")
layout=${layout%% *}

if [ -z "$layout" ]; then
  exec zsh
fi

find ~ -type d -maxdepth 3 2>/dev/null \
  | fzf --prompt="Directory> " --query="$HOME" --height=40% --reverse --preview 'ls {}' > "$tmpfile"
dir=$(<"$tmpfile")

if [ -z "$dir" ]; then
  exec zsh
fi

# Create, attach, and set up layout in one tmux call.
# destroy-unattached is set after the client is attached, so it only fires on close.
case "$layout" in
  1)
    exec tmux new-session -c "$dir" \
      ';' set-option destroy-unattached on
    ;;
  2)
    exec tmux new-session -c "$dir" \
      ';' set-option destroy-unattached on \
      ';' split-window -h -c "$dir" \
      ';' select-pane -t 0
    ;;
  3)
    exec tmux new-session -c "$dir" \
      ';' set-option destroy-unattached on \
      ';' split-window -h -c "$dir" \
      ';' split-window -v -c "$dir" \
      ';' select-pane -t 0
    ;;
  4)
    exec tmux new-session -c "$dir" \
      ';' set-option destroy-unattached on \
      ';' split-window -h -c "$dir" \
      ';' select-pane -t 0 \
      ';' split-window -v -c "$dir" \
      ';' select-pane -t 1 \
      ';' split-window -v -c "$dir" \
      ';' select-pane -t 0
    ;;
esac
